---
import { getCollection } from "astro:content";

export interface Props {
  currentSlug?: string;
}

const { currentSlug = "" } = Astro.props;

const docs = await getCollection("docs");
const sorted = docs
  .filter((d) => !d.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<nav class="shrink-0 w-52 md:w-44" aria-label="Docs navigation">
  <ul class="flex flex-col gap-[2px] list-none p-0">
    {sorted.map((doc) => {
      const slug = doc.slug;
      const isActive = currentSlug === slug;
      return (
        <li>
          <a
            href={`/docs/${slug}`}
            class={`block nc-text-sm no-underline py-1.5 px-3 rounded-r-sm border-l-2 hover:text-[--nc-ink] hover:bg-[--nc-hover] ${
              isActive
                ? "nc-font-medium border-[--nc-accent] bg-[--nc-accent-subtle] text-[--nc-ink]"
                : "text-[--nc-ink-2] border-transparent"
            }`}
          >
            {doc.data.title}
          </a>
        </li>
      );
    })}
  </ul>
</nav>
