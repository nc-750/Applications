---
import Wordmark from "./Wordmark.astro";

export interface FooterLink {
  label: string;
  href: string;
}

export interface LinkGroup {
  title: string;
  links: FooterLink[];
}

export interface Props {
  groups?: LinkGroup[];
}

const {
  groups = [
    {
      title: "Docs",
      links: [
        { label: "User Guide", href: "/docs/user-guide" },
        { label: "Provider Setup", href: "/docs/provider-setup" },
        { label: "Privacy", href: "/docs/privacy" },
        { label: "FAQ", href: "/docs/faq" },
      ],
    },
    {
      title: "App",
      links: [
        { label: "Download", href: "/download" },
        { label: "Compare plans", href: "/#compare" },
      ],
    },
  ],
} = Astro.props;
---

<footer class="border-t border-(--nc-line) bg-[--nc-panel]">
  <div class="nc-shell">
    <div class="grid grid-cols-3 gap-8 mb-10 max-md:grid-cols-2 max-sm:grid-cols-1">
      <!-- Brand column -->
      <div>
        <Wordmark />
        <p class="nc-caption mt-3 max-w-[28ch]">
          Your career, understood honestly. Private, honest, and yours forever.
        </p>
      </div>

      <!-- Link groups -->
      {groups.map((group) => (
        <div>
          <h4 class="nc-label block mb-3">{group.title}</h4>
          <ul class="flex flex-col gap-2 list-none p-0">
            {group.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="nc-text-sm nc-text-secondary no-underline hover:text-[--nc-ink]"
                  {...(link.href.startsWith("http") ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <hr class="nc-divider nc-divider--subtle mb-6" />
    <div class="flex justify-between max-sm:flex-col max-sm:gap-6">
      <p class="nc-text-xs nc-text-muted">
        Built by Alex Vendinois. No account. No tracking.
      </p>
      <p class="nc-partno">Mirror v0.1.0</p>
    </div>
  </div>
</footer>
