---
export interface Props {
  size?: number;
  class?: string;
}

const { size = 24, class: className = "" } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  aria-hidden="true"
  class={className}
>
  <rect
    x="3.75" y="3.75"
    width="16.5" height="16.5"
    rx="3.5"
    stroke="currentColor"
    stroke-width="1.5"
  />
  <rect
    x="9" y="9"
    width="6" height="6"
    rx="0.75"
    stroke="currentColor"
    stroke-width="1.5"
    transform="rotate(45 12 12)"
  />
</svg>
