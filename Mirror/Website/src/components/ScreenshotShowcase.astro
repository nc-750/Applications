<!-- Screenshot showcase — app screenshots go in public/screenshots/ -->
<section class="border-t border-(--nc-line)">
    <div class="nc-shell py-20 pb-28">
        <h2 class="nc-heading-2 mb-3">See it in action</h2>
        <p class="nc-text-base nc-text-secondary mb-12 max-w-prose">
            A warm, conversational interview produces a private insight document
            and a polished public profile. Both downloadable as standalone HTML.
        </p>

        <!-- Screenshot grid -->
        <div class="grid grid-cols-2 gap-6 max-sm:grid-cols-1">
            <div class="nc-panel overflow-hidden p-0">
                <div class="aspect-video bg-[--nc-bg]">
                    <img
                        src="/screenshots/desktop/light/Interview_Desktop_Light.png"
                        alt="Mirror interview screen showing a chat-style conversation with an AI interviewer"
                        width="1600"
                        height="1000"
                        loading="lazy"
                        class="theme-img-light w-full h-full object-cover"
                    />
                    <img
                        src="/screenshots/desktop/dark/Interview_Desktop_Dark.png"
                        alt="Mirror interview screen showing a chat-style conversation with an AI interviewer"
                        width="1600"
                        height="1000"
                        loading="lazy"
                        class="theme-img-dark hidden w-full h-full object-cover"
                    />
                </div>
                <div class="border-t border-(--nc-line) p-3">
                    <p class="nc-text-sm nc-font-medium mb-0.5">The interview</p>
                    <p class="nc-caption">
                        Conversational, not a form. Your AI, your pace.
                    </p>
                </div>
            </div>
            <div class="nc-panel overflow-hidden p-0">
                <div class="aspect-video bg-[--nc-bg]">
                    <img
                        src="/screenshots/desktop/light/Profile_Desktop_Light.png"
                        alt="Mirror profile page showing a polished professional profile with skills and timeline"
                        width="1600"
                        height="1000"
                        loading="lazy"
                        class="theme-img-light w-full h-full object-cover"
                    />
                    <img
                        src="/screenshots/desktop/dark/Profile_Desktop_Dark.png"
                        alt="Mirror profile page showing a polished professional profile with skills and timeline"
                        width="1600"
                        height="1000"
                        loading="lazy"
                        class="theme-img-dark hidden w-full h-full object-cover"
                    />
                </div>
                <div class="border-t border-(--nc-line) p-3">
                    <p class="nc-text-sm nc-font-medium mb-0.5">Public profile</p>
                    <p class="nc-caption">
                        Polished, shareable, recruiter-ready. No lock-in.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
  function updateThemedImages() {
    const isDark = document.documentElement.hasAttribute('data-theme');
    document.querySelectorAll('.theme-img-light').forEach(el => el.classList.toggle('hidden', isDark));
    document.querySelectorAll('.theme-img-dark').forEach(el => el.classList.toggle('hidden', !isDark));
  }

  document.addEventListener('DOMContentLoaded', () => {
    updateThemedImages();
    new MutationObserver(() => updateThemedImages())
      .observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  });
</script>
