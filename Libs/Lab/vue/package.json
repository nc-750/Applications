{
  "name": "@nc-750/lab-vue",
  "version": "0.1.0",
  "description": "Typed Vue 3 facade over the Lab (.nc-*) design system.",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/lab-vue.umd.cjs",
  "module": "./dist/lab-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/lab-vue.js",
      "require": "./dist/lab-vue.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -p tsconfig.build.json && vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vue": "^3.5.13",
    "vue-tsc": "^2.1.10"
  }
}
