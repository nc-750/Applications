---
import Wordmark from "./Wordmark.astro";
import ThemeToggle from "./ThemeToggle.astro";
import Button from "./Button.astro";

export interface NavLink {
    label: string;
    href: string;
}

export interface Props {
    currentPath?: string;
    links?: NavLink[];
    ctaHref?: string;
    ctaLabel?: string;
}

const {
    currentPath = "/",
    links = [
        { label: "Docs", href: "/docs/user-guide" },
        { label: "Download", href: "/download" },
    ],
    ctaHref = "#download",
    ctaLabel = "Get Mirror",
} = Astro.props;
---

<nav class="sticky top-0 z-50 border-b border-(--nc-line)" aria-label="Main">
    <div class="nc-shell flex items-center justify-between">
        <!-- Logo -->
        <Wordmark />

        <!-- Desktop nav links -->
        <div class="nav-desktop flex items-center gap-6">
            {
                links.map((link) => (
                    <a
                        href={link.href}
                        class={`nc-text-sm no-underline hover:underline hover:decoration-[--nc-accent] underline-offset-2 ${
                            currentPath === link.href
                                ? "nc-font-medium text-[--nc-ink]"
                                : "text-[--nc-ink-2] hover:text-[--nc-ink]"
                        }`}
                    >
                        {link.label}
                    </a>
                ))
            }
        </div>

        <!-- Desktop right: CTA + theme -->
        <div class="nav-desktop flex items-center gap-3">
            <Button variant="primary" size="sm" href={ctaHref}>
                {ctaLabel}
            </Button>
            <ThemeToggle />
        </div>

        <!-- Mobile: theme + hamburger -->
        <div class="nav-mobile flex items-center gap-2">
            <ThemeToggle />
            <button
                id="mobile-menu-toggle"
                type="button"
                class="inline-flex items-center justify-center w-11 h-11 rounded-md text-[--nc-ink-2] hover:text-[--nc-ink] hover:bg-[--nc-hover] border-0 bg-transparent cursor-pointer transition-colors"
                aria-label="Toggle menu"
                aria-expanded="false"
                aria-controls="mobile-menu"
            >
                <svg
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                >
                    <line x1="4" y1="6" x2="20" y2="6"></line>
                    <line x1="4" y1="12" x2="20" y2="12"></line>
                    <line x1="4" y1="18" x2="20" y2="18"></line>
                </svg>
            </button>
        </div>
    </div>

    <!-- Mobile menu: slides open with max-height transition -->
    <div id="mobile-menu" class="mobile-menu border-t border-(--nc-line)">
        <div class="flex flex-col gap-2">
            {
                links.map((link) => (
                    <a
                        href={link.href}
                        class="mobile-menu-link block nc-text-sm no-underline min-h-[44px] flex items-center px-3 hover:bg-[--nc-hover] rounded-sm"
                        class:list={[
                            currentPath === link.href
                                ? "nc-font-medium text-[--nc-ink]"
                                : "text-[--nc-ink-2]",
                        ]}
                    >
                        {link.label}
                    </a>
                ))
            }
            <div>
                <Button variant="primary" size="sm" href={ctaHref}>
                    {ctaLabel}
                </Button>
            </div>
        </div>
    </div>
</nav>

<style>
    /* Desktop-only: show nav-desktop, hide nav-mobile */
    .nav-desktop {
        display: none;
    }
    .nav-mobile {
        display: flex;
    }

    @media (min-width: 641px) {
        .nav-desktop {
            display: flex;
        }
        .nav-mobile {
            display: none;
        }
    }

    /* Mobile menu: smooth slide-down via max-height + opacity */
    .mobile-menu {
        max-height: 0;
        opacity: 0;
        overflow: hidden;
        transition:
            max-height 280ms cubic-bezier(0.4, 0, 0.2, 1),
            opacity 200ms cubic-bezier(0.4, 0, 0.2, 1);
    }
    .mobile-menu.is-open {
        max-height: 400px;
        opacity: 1;
    }

    /* Reduced motion: kill all transition durations */
    @media (prefers-reduced-motion: reduce) {
        .mobile-menu {
            transition-duration: 0.01ms;
        }
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const toggle = document.getElementById("mobile-menu-toggle");
        const menu = document.getElementById("mobile-menu");
        if (!toggle || !menu) return;

        function closeMenu() {
            menu.classList.remove("is-open");
            toggle.setAttribute("aria-expanded", "false");
        }

        function openMenu() {
            menu.classList.add("is-open");
            toggle.setAttribute("aria-expanded", "true");
        }

        toggle.addEventListener("click", () => {
            if (menu.classList.contains("is-open")) {
                closeMenu();
            } else {
                openMenu();
            }
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && menu.classList.contains("is-open")) {
                closeMenu();
                toggle.focus();
            }
        });
    });
</script>
