---
import { LANDING_FEATURES } from "../config.ts";

const cellVariants: Record<number, string> = {
  0: "",
  1: "--2",
  2: "--brushed",
};
---

<section class="nc-shell py-20 pb-28" aria-labelledby="features-heading">
  <h2 id="features-heading" class="nc-heading-2 mb-10">What Mirror offers</h2>

  <div class="nc-module rounded-xl">
    <div class="nc-faceplate nc-faceplate--cols-3">
      {LANDING_FEATURES.map((feature, i) => (
        <div class={`nc-cell${cellVariants[i] ? ` nc-cell${cellVariants[i]}` : ""}`}>
          <span class="nc-partno block mb-1">
            {(i + 1).toString().padStart(2, "0")}
          </span>
          <h3 class="nc-heading-4 mb-2">{feature.title}</h3>
          <p class="nc-text-sm nc-text-secondary max-w-prose">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
