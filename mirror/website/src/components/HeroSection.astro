---
import LogoMark from "./LogoMark.astro";
import Button from "./Button.astro";
import { SITE, DOWNLOAD } from "../config.ts";
---

<section class="relative overflow-hidden">
  <div class="nc-shell pt-20 pb-16">
    <div class="flex flex-col items-center max-w-3xl mx-auto">
      <!-- Logo mark -->
      <div class="mb-8">
        <span class="inline-flex items-center justify-center rounded-lg w-14 h-14 bg-[--nc-accent-subtle] text-[--nc-accent]">
          <LogoMark size={28} />
        </span>
      </div>

      <!-- Headline -->
      <h1 class="nc-display text-center mb-5">
        {SITE.tagline}
      </h1>

      <!-- Subheadline -->
      <p class="nc-text-lg nc-text-secondary text-center mb-9 max-w-prose">
        {SITE.description}
      </p>

      <!-- CTAs -->
      <div class="flex justify-center gap-3">
        <Button variant="primary" size="md" href={DOWNLOAD.githubReleases} external>
          Download Mirror
        </Button>
        <Button variant="ghost" size="md" href="#how-it-works">
          How it works
        </Button>
      </div>

      <!-- Privacy footnote -->
      <p class="nc-label nc-label--accent text-center mt-6">
        Free &amp; open source. No account. Bring your own AI key.
      </p>
    </div>
  </div>

  <!-- Subtle background watermark -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 -z-10 text-[--nc-line] opacity-20 pointer-events-none" aria-hidden="true">
    <LogoMark size={320} />
  </div>
</section>
