---
import MarketingLayout from "../components/MarketingLayout.astro";
import LogoMark from "../components/LogoMark.astro";
---

<MarketingLayout title="Page not found — Mirror" currentPath="">
  <div class="flex items-center justify-center min-h-[60vh]">
    <div class="text-center px-4">
      <span class="inline-flex items-center justify-center mb-6 rounded-lg w-12 h-12 bg-[--nc-accent-subtle] text-[--nc-accent]">
        <LogoMark size={24} />
      </span>
      <h1 class="nc-heading-2 mb-3">Page not found</h1>
      <p class="nc-text-base nc-text-secondary mb-6 mx-auto max-w-prose">
        This page doesn't exist. The site is simple — maybe try the home page?
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 nc-text-base nc-font-medium no-underline text-[--nc-accent] hover:text-[--nc-accent-hover]"
      >
        &larr; Back home
      </a>
    </div>
  </div>
</MarketingLayout>
