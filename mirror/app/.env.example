# Copy this file to .env.local and fill in real values.
# .env.local is gitignored (matched by *.local) and never committed.
#
# Single source for BOTH the Tauri desktop build and the PWA build — Vite inlines
# it into the frontend at build time. It is a public Lemon Squeezy checkout URL
# (no secret), so bundling it is fine. CI/CD should inject this per environment
# when building production binaries / the PWA; different environments (test vs.
# live store) can supply different URLs.

# The purchase page URL shown in the "Buy a license" button.
VITE_LS_STORE_URL=https://your-store.lemonsqueezy.com/buy/your-product-uuid

# Interview token budget — characters before the LLM digest pre-pass fires (default 600000 ≈ 170k tokens)
# Set lower (e.g. 5000) to force-trigger the digest for testing
VITE_DIGEST_THRESHOLD_CHARS=600000

# Digest chunk size in characters per map-reduce pass (default 80000 ≈ 23k tokens)
VITE_DIGEST_CHUNK_CHARS=80000
