---
import { DOWNLOAD } from "../config.ts";
import Button from "./Button.astro";
---

<section id="download" class="border-t border-(--nc-line)">
  <div class="py-20 pb-28">
    <h2 class="nc-heading-2 text-center mb-10">Download</h2>

    <div class="grid grid-cols-2 gap-6 max-sm:grid-cols-1 mx-auto max-w-2xl">
      <!-- Desktop -->
      <div class="nc-panel text-center">
        <h3 class="nc-heading-4 mb-2">Desktop app</h3>
        <p class="nc-text-sm nc-text-secondary mb-1">{DOWNLOAD.platforms.join(" · ")}</p>
        <p class="nc-caption mb-5">Free &amp; open source. Built with Tauri.</p>
        <Button variant="primary" size="sm" href={DOWNLOAD.githubReleases} external>
          GitHub Releases
        </Button>
      </div>

      <!-- PWA -->
      <div class="nc-panel text-center">
        <h3 class="nc-heading-4 mb-2">Web app (PWA)</h3>
        <p class="nc-text-sm nc-text-secondary mb-1">Any modern browser</p>
        <p class="nc-caption mb-5">Install to your device. No download required.</p>
        <Button variant="secondary" size="sm" href={DOWNLOAD.pwaUrl} external>
          Open PWA
        </Button>
      </div>
    </div>

    <p class="nc-text-sm nc-text-muted text-center mt-8">
      Pro license activates in both the desktop app and PWA.{" "}
      <a href="https://github.com/vendinois/persona" class="nc-text-secondary underline underline-offset-2 hover:text-[--nc-ink]" target="_blank" rel="noopener noreferrer">
        Source code on GitHub
      </a>.
    </p>
  </div>
</section>
