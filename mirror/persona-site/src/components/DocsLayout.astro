---
import BaseLayout from "./BaseLayout.astro";
import NavBar from "./NavBar.astro";
import Footer from "./Footer.astro";
import DocSidebar from "./DocSidebar.astro";

export interface Props {
  title?: string;
  description?: string;
  currentSlug?: string;
}

const { title, description, currentSlug = "" } = Astro.props;
---

<BaseLayout {title} {description} pathname={`/docs/${currentSlug}`}>
  <NavBar currentPath={`/docs/${currentSlug}`} />

  <div class="nc-shell">
    <div class="flex gap-8 max-sm:flex-col">
      <!-- Sidebar -->
      <DocSidebar currentSlug={currentSlug} />

      <!-- Content -->
      <main class="flex-1 min-w-0">
        <div class="nc-prose">
          <slot />
        </div>

        <!-- Edit link -->
        <hr class="nc-divider nc-divider--subtle mt-12" />
        <div class="mt-6">
          <a
            href={`https://github.com/vendinois/persona/edit/main/persona-site/src/content/docs/${currentSlug}.md`}
            class="nc-text-sm nc-text-muted no-underline hover:text-[--nc-ink-2]"
            target="_blank"
            rel="noopener noreferrer"
          >
            Edit this page on GitHub &rarr;
          </a>
        </div>
      </main>
    </div>
  </div>

  <Footer />
</BaseLayout>
