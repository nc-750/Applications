---
import { HOW_IT_WORKS_STEPS } from "../config.ts";
---

<section id="how-it-works" class="border-t border-(--nc-line)">
  <div class="nc-shell py-20 pb-28">
    <h2 class="nc-heading-2 mb-12">How it works</h2>

    <div class="grid grid-cols-3 gap-6 max-md:grid-cols-2 max-sm:grid-cols-1 max-sm:gap-8">
      {HOW_IT_WORKS_STEPS.map((step) => (
        <div>
          <!-- Step number -->
          <div class="inline-flex items-center justify-center mb-4 rounded-lg w-10 h-10 border-[1.5px] border-[--nc-accent] text-[--nc-accent] nc-text-sm nc-font-semibold">
            {step.step}
          </div>

          <h3 class="nc-heading-4 mb-2">{step.title}</h3>
          <p class="nc-text-sm nc-text-secondary max-w-prose">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
