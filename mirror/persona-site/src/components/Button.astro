---
export interface Props {
  variant?: "primary" | "secondary" | "ghost";
  href?: string;
  external?: boolean;
  size?: "sm" | "md";
}

const {
  variant = "primary",
  href,
  external = false,
  size = "md",
} = Astro.props;

const variantClass: Record<string, string> = {
  primary: "nc-btn--primary",
  secondary: "nc-btn--secondary",
  accent: "nc-btn--accent",
  ghost: "nc-btn--ghost",
};

const sizeClass: Record<string, string> = {
  sm: "nc-btn--sm",
  md: "",
};

const cls = [
  "nc-btn",
  variantClass[variant],
  sizeClass[size],
].filter(Boolean).join(" ");

const rel = external ? "noopener noreferrer" : "";
const target = external ? "_blank" : "";
---

{href ? (
  <a href={href} class={cls} {rel} {target}>
    <slot />
  </a>
) : (
  <button class={cls}>
    <slot />
  </button>
)}
