---
import MarketingLayout from "../components/MarketingLayout.astro";
import LogoMark from "../components/LogoMark.astro";
import Button from "../components/Button.astro";
import {
    SITE,
    PRICING,
    DOWNLOAD,
    LANDING_FEATURES,
    HOW_IT_WORKS_STEPS,
    COMPARISON_FEATURES,
} from "../config.ts";

const jsonLd = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Persona",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Windows, macOS, Linux, Web",
    description: SITE.description,
    offers: {
        "@type": "Offer",
        price: "29",
        priceCurrency: "USD",
        description: PRICING.proPriceLabel,
    },
    author: {
        "@type": "Person",
        name: SITE.author,
    },
});
---

<script type="application/ld+json" set:html={jsonLd} />

<MarketingLayout>
    <div class="nc-shell">
        <div class="nc-module rounded-xl">
            <div class="nc-faceplate nc-faceplate--cols-3">
                <!-- Hero -->
                <div class="nc-cell col-span-full">
                    <div class="flex flex-col items-center">
                        <span class="inline-flex items-center justify-center mb-6">
                            <LogoMark size={24} />
                        </span>
                        <h1 class="nc-display text-center mb-4">
                            {SITE.tagline}
                        </h1>
                        <p class="nc-text-lg nc-text-secondary text-center mb-8">
                            {SITE.description}
                        </p>
                        <div class="flex justify-center gap-3 mb-6">
                            <Button
                                variant="accent"
                                size="md"
                                href={DOWNLOAD.githubReleases}
                                external
                            >
                                Download Persona
                            </Button>
                            <Button variant="ghost" size="md" href="#compare">
                                Compare Free &amp; Pro
                            </Button>
                        </div>
                        <p class="nc-caption--accent text-center">
                            No account. Bring your own AI key.
                        </p>
                    </div>
                </div>

                <!-- Feature 1: Private by design -->
                <div class="nc-cell nc-cell--brushed">
                    <span class="nc-partno block mb-2">01</span>
                    <h3 class="nc-heading-4 mb-2">
                        {LANDING_FEATURES[0].title}
                    </h3>
                    <p class="nc-text-sm nc-text-secondary">
                        {LANDING_FEATURES[0].description}
                    </p>
                </div>

                <!-- Insight excerpt: console surface -->
                <div class="nc-cell nc-cell--dark col-span-2 max-sm:col-span-1 relative">
                    <div class="nc-reg" aria-hidden="true"></div>
                    <span class="nc-lcd-sub block mb-3">Sample insight</span>
                    <p class="mb-3">
                        "You build structured frameworks before acting. This
                        pattern repeats across three roles and two industries.
                        It is your most transferable asset, and it is
                        undervalued in your current positioning."
                    </p>
                    <span class="nc-lcd-sub">
                        Persona Insight, Growth Patterns
                    </span>
                </div>

                <!-- Screenshot panel -->
                <div class="nc-cell col-span-2 max-sm:col-span-1">
                    <div class="aspect-video relative">
                        <div
                            class="absolute inset-0 flex items-center justify-center"
                            aria-hidden="true"
                        >
                            <div class="nc-reg"></div>
                        </div>
                        <img
                            src="/screenshots/desktop/light/Interview_Desktop_Light.png"
                            alt="The Persona interview screen showing a chat-style conversation with an AI interviewer"
                            width="1600"
                            height="1000"
                            loading="lazy"
                            class="theme-img-light w-full h-full object-cover relative"
                        />
                        <img
                            src="/screenshots/desktop/dark/Interview_Desktop_Dark.png"
                            alt="The Persona interview screen showing a chat-style conversation with an AI interviewer"
                            width="1600"
                            height="1000"
                            loading="lazy"
                            class="theme-img-dark hidden w-full h-full object-cover relative"
                        />
                    </div>
                    <div class="border-t border-(--nc-line) pt-3 mt-3">
                        <p class="nc-text-sm nc-font-medium mb-1">The interview</p>
                        <p class="nc-caption">
                            Conversational, not a form. Your AI, your pace.
                        </p>
                    </div>
                </div>

                <!-- Feature 3: Yours forever -->
                <div class="nc-cell nc-cell--2">
                    <span class="nc-partno block mb-2">02</span>
                    <h3 class="nc-heading-4 mb-2">
                        {LANDING_FEATURES[2].title}
                    </h3>
                    <p class="nc-text-sm nc-text-secondary">
                        {LANDING_FEATURES[2].description}
                    </p>
                </div>

                <!-- How it works -->
                <div class="nc-cell col-span-2 max-sm:col-span-1">
                    <h3 class="nc-heading-4 mb-4">How it works</h3>
                    <div class="flex flex-col gap-4">
                        {
                            HOW_IT_WORKS_STEPS.map((step) => (
                                <div class="flex gap-2">
                                    <span class="nc-font-semibold shrink-0">
                                        {step.step}. {step.title}
                                    </span>
                                    <span class="nc-caption">
                                        {step.description}
                                    </span>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <!-- Pricing CTA -->
                <div class="nc-cell nc-cell--dark">
                    <span class="nc-label nc-label--accent block mb-2">
                        Pro license
                    </span>
                    <div class="mb-3">
                        <span class="nc-lcd nc-lcd--lg">
                            {PRICING.proPriceRange}
                        </span>
                    </div>
                    <p class="nc-text-sm nc-text-secondary mb-5">
                        {PRICING.proPriceLabel}
                    </p>
                    <Button
                        variant="accent"
                        size="sm"
                        href={PRICING.lemonSqueezyUrl}
                        external
                    >
                        Buy Persona Pro
                    </Button>
                </div>

                <!-- Comparison table -->
                <div id="compare" class="nc-cell col-span-full">
                    <h3 class="nc-heading-4 mb-4">Free vs Pro</h3>
                    <div class="overflow-x-auto">
                        <table class="nc-table">
                            <thead>
                                <tr>
                                    <th>Feature</th>
                                    <th class="text-center">Free</th>
                                    <th class="text-center nc-text--accent">
                                        Pro
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                {
                                    COMPARISON_FEATURES.map((row) => (
                                        <tr>
                                            <td class="nc-font-medium">
                                                {row.feature}
                                            </td>
                                            <td class="text-center nc-text-secondary">
                                                {row.free}
                                            </td>
                                            <td class="text-center nc-text-secondary">
                                                {row.pro}
                                            </td>
                                        </tr>
                                    ))
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Desktop app CTA -->
                <div class="nc-cell text-center">
                    <h3 class="nc-heading-4 mb-2">Desktop app</h3>
                    <p class="nc-text-sm nc-text-secondary mb-1">
                        {DOWNLOAD.platforms.join(" · ")}
                    </p>
                    <p class="nc-caption mb-5">Lightweight and fast</p>
                    <Button
                        variant="primary"
                        size="sm"
                        href={DOWNLOAD.githubReleases}
                        external
                    >
                        Download
                    </Button>
                </div>

                <!-- PWA CTA -->
                <div class="nc-cell nc-cell--2 text-center">
                    <h3 class="nc-heading-4 mb-2">Web app</h3>
                    <p class="nc-text-sm nc-text-secondary mb-1">
                        Use any browser
                    </p>
                    <p class="nc-caption mb-5">Installable on your device</p>
                    <Button
                        variant="secondary"
                        size="sm"
                        href={DOWNLOAD.pwaUrl}
                        external
                    >
                        Open
                    </Button>
                </div>

                <!-- License info -->
                <div class="nc-cell">
                    <span class="nc-label block mb-2">
                        One license to rule them all
                    </span>
                    <p class="nc-caption mb-3">
                        Pro license valid for all devices. Unlimited.
                    </p>
                    <div class="nc-barcode mt-5" aria-hidden="true"></div>
                </div>
            </div><!-- /nc-faceplate -->
        </div><!-- /nc-module -->
    </div><!-- /nc-shell -->
</MarketingLayout>

<script>
  function updateThemedImages() {
    const isDark = document.documentElement.hasAttribute('data-theme');
    document.querySelectorAll('.theme-img-light').forEach(el => el.classList.toggle('hidden', isDark));
    document.querySelectorAll('.theme-img-dark').forEach(el => el.classList.toggle('hidden', !isDark));
  }

  document.addEventListener('DOMContentLoaded', () => {
    updateThemedImages();
    new MutationObserver(() => updateThemedImages())
      .observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  });
</script>
